<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAG Chatbot - Registered Key Authentication Test</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }
        
        h1 {
            color: #333;
            text-align: center;
            margin-bottom: 30px;
        }
        
        .section {
            margin-bottom: 30px;
            padding: 20px;
            border: 1px solid #e1e5e9;
            border-radius: 8px;
            background: #f8f9fa;
        }
        
        .form-group {
            margin-bottom: 15px;
        }
        
        label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
            color: #333;
        }
        
        input[type="text"], input[type="password"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            box-sizing: border-box;
        }
        
        button {
            background: #007bff;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            margin-right: 10px;
            margin-bottom: 10px;
        }
        
        button:hover {
            background: #0056b3;
        }
        
        button:disabled {
            background: #6c757d;
            cursor: not-allowed;
        }
        
        .status {
            padding: 10px;
            border-radius: 4px;
            margin: 10px 0;
        }
        
        .status.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        
        .status.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        
        .status.info {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }
        
        .code-block {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 4px;
            padding: 15px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            overflow-x: auto;
            margin: 10px 0;
        }
        
        .instructions {
            background: #e7f3ff;
            border-left: 4px solid #007bff;
            padding: 15px;
            margin: 20px 0;
        }
        
        .instructions h3 {
            margin-top: 0;
            color: #007bff;
        }
        
        .instructions ol {
            margin: 10px 0;
            padding-left: 20px;
        }
        
        .instructions li {
            margin-bottom: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔑 RAG Chatbot - Registered Key Authentication Test</h1>
        
        <div class="instructions">
            <h3>📋 How to use Registered Key Authentication:</h3>
            <ol>
                <li><strong>Register a user</strong> in the upload portal (http://localhost:3001/register)</li>
                <li><strong>Copy the public key</strong> that's generated during registration</li>
                <li><strong>Enter your username</strong> below to test the chatbot</li>
                <li><strong>Initialize the chatbot</strong> with registered key authentication</li>
            </ol>
        </div>

        <div class="section">
            <h2>🔑 Registered Key Authentication</h2>
            
            <div class="form-group">
                <label for="username">Username (from registration):</label>
                <input type="text" id="username" placeholder="Enter your registered username">
            </div>
            
            <button onclick="testRegisteredKeyAuth()">Test Registered Key Authentication</button>
            <button onclick="initializeChatbot()">Initialize Chatbot</button>
            <button onclick="clearStatus()">Clear Status</button>
            
            <div id="auth-status"></div>
        </div>

        <div class="section">
            <h2>📝 Configuration Example</h2>
            <p>Here's how to configure the chatbot with registered key authentication:</p>
            
            <div class="code-block">
// Initialize chatbot with registered key authentication
initRAGChatbot({
    backendUrl: 'http://localhost:8001',
    auth: {
        useRegisteredKey: true,
        registeredUsername: 'your_username_here',
        uploadPortalUrl: 'http://localhost:3001',
        publicKeyEndpoint: '/api/auth/public-key'
    }
});
            </div>
        </div>

        <div class="section">
            <h2>🔍 Test Results</h2>
            <div id="test-results"></div>
        </div>
    </div>

    <script src="chatbot.js"></script>
    <script>
        let authToken = null;
        let userId = null;

        function showStatus(message, type = 'info') {
            const statusDiv = document.getElementById('auth-status');
            statusDiv.innerHTML = `<div class="status ${type}">${message}</div>`;
        }

        function showTestResult(message, type = 'info') {
            const resultsDiv = document.getElementById('test-results');
            const timestamp = new Date().toLocaleTimeString();
            resultsDiv.innerHTML += `<div class="status ${type}">[${timestamp}] ${message}</div>`;
        }

        function clearStatus() {
            document.getElementById('auth-status').innerHTML = '';
            document.getElementById('test-results').innerHTML = '';
        }

        async function testRegisteredKeyAuth() {
            const username = document.getElementById('username').value;
            
            if (!username) {
                showStatus('Please enter a username', 'error');
                return;
            }

            showStatus('Testing registered key authentication...', 'info');
            showTestResult(`Testing authentication for username: ${username}`, 'info');

            try {
                // Test fetching public key
                const publicKeyResponse = await fetch(`http://localhost:3001/api/auth/public-key/${username}`);
                
                if (!publicKeyResponse.ok) {
                    const error = await publicKeyResponse.json();
                    throw new Error(error.message || 'Failed to fetch public key');
                }

                const publicKeyData = await publicKeyResponse.json();
                showTestResult(`✅ Public key fetched successfully`, 'success');
                showTestResult(`Public key length: ${publicKeyData.publicKey.length} characters`, 'info');

                // Test registered key authentication
                const authResponse = await fetch('http://localhost:8001/auth/register-key', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        public_key: publicKeyData.publicKey,
                        username: username
                    })
                });

                if (!authResponse.ok) {
                    const error = await authResponse.json();
                    throw new Error(error.detail || 'Failed to authenticate with registered key');
                }

                const authData = await authResponse.json();
                showTestResult(`✅ Registered key authentication successful`, 'success');
                showTestResult(`User ID: ${authData.user_id}`, 'info');
                showTestResult(`Token received: ${authData.token.substring(0, 20)}...`, 'info');

                showStatus('✅ Registered key authentication test successful!', 'success');
                showTestResult(`✅ All tests passed for username: ${username}`, 'success');

            } catch (error) {
                showStatus(`❌ Test failed: ${error.message}`, 'error');
                showTestResult(`❌ Error: ${error.message}`, 'error');
            }
        }

        async function initializeChatbot() {
            const username = document.getElementById('username').value;
            
            if (!username) {
                showStatus('Please enter a username first', 'error');
                return;
            }

            showStatus('Initializing chatbot with registered key authentication...', 'info');
            showTestResult(`Initializing chatbot for username: ${username}`, 'info');

            try {
                // Initialize chatbot with registered key authentication
                const iframe = await initRAGChatbot({
                    backendUrl: 'http://localhost:8001',
                    auth: {
                        useRegisteredKey: true,
                        registeredUsername: username,
                        uploadPortalUrl: 'http://localhost:3001',
                        publicKeyEndpoint: '/api/auth/public-key'
                    }
                });

                showStatus('✅ Chatbot initialized successfully!', 'success');
                showTestResult(`✅ Chatbot iframe created and initialized`, 'success');
                showTestResult(`You can now chat with the bot using your registered key authentication`, 'info');

            } catch (error) {
                showStatus(`❌ Chatbot initialization failed: ${error.message}`, 'error');
                showTestResult(`❌ Error: ${error.message}`, 'error');
            }
        }

        // Auto-test on page load
        window.addEventListener('load', function() {
            showStatus('Ready to test registered key authentication. Enter a username and click "Test Registered Key Authentication"', 'info');
        });
    </script>
</body>
</html> 