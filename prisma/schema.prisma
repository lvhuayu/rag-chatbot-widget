generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:C:/Users/huayulu/RAG/rag-chatbot-widget/backend/rag_database.db"
}

model api_keys {
  id         String   @id @default(cuid())
  site_id    String
  api_key    String   @unique
  allowed_origins String
  rate_limit Int?     @default(1000)
  is_active  Boolean? @default(true)
  created_at DateTime @default(now())
  sites      sites    @relation(fields: [site_id], references: [site_id])
}

model billing_plans {
  id                 String               @id
  name               String
  monthly_price      Int
  daily_limit        Int?
  features           String?
  site_subscriptions site_subscriptions[]
}

model chat_logs {
  id          String   @id
  site_id     String
  session_id  String?
  question    String
  answer      String
  model_used  String?
  token_usage Int?
  timestamp   DateTime @default(now())
  sites       sites    @relation(fields: [site_id], references: [site_id])
}

model documents {
  id         String       @id
  site_id    String
  title      String?
  url        String?
  content    String
  created_at DateTime     @default(now())
  sites      sites        @relation(fields: [site_id], references: [site_id])
  embeddings embeddings[]
}

model embeddings {
  id               String    @id
  document_id      String
  site_id          String
  embedding_vector Bytes
  dimension        Int
  created_at       DateTime  @default(now())
  sites            sites     @relation(fields: [site_id], references: [site_id])
  documents        documents @relation(fields: [document_id], references: [id])
}

model site_subscriptions {
  id            String        @id
  site_id       String
  plan_id       String
  start_date    DateTime      @default(now())
  expire_date   DateTime?
  billing_plans billing_plans @relation(fields: [plan_id], references: [id])
  sites         sites         @relation(fields: [site_id], references: [site_id])
}

model sites {
  site_id            String               @id @default(cuid())
  user_id            String
  site_name          String?
  allowed_origins    String?
  style_config       String?
  model              String?
  status             String?              @default("active")
  created_at         DateTime             @default(now())
  updated_at         DateTime?
  api_keys           api_keys[]
  chat_logs          chat_logs[]
  documents          documents[]
  embeddings         embeddings[]
  site_subscriptions site_subscriptions[]
  users              users                @relation(fields: [user_id], references: [id])
}

model users {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  email         String?
  created_at    DateTime @default(now())
  sites         sites[]
}
